From aaa5f17f626b9dd1da1ebba7c05250c75eea26d7 Mon Sep 17 00:00:00 2001
From: Alex Gonzalez <alexg@balena.io>
Date: Tue, 8 Oct 2024 17:56:38 +0200
Subject: [PATCH] defconfig: cl-imx8m-mini: extend bootloader command line

Extend the command line to always boot the balena bootloader with the
appropriate argument.

Signed-off-by: Alex Gonzalez <alexg@balena.io>
---
 arch/arm64/configs/cl-imx8m-mini_defconfig | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/arch/arm64/configs/cl-imx8m-mini_defconfig b/arch/arm64/configs/cl-imx8m-mini_defconfig
index 8fe17f8c4268..cd8c88e97091 100644
--- a/arch/arm64/configs/cl-imx8m-mini_defconfig
+++ b/arch/arm64/configs/cl-imx8m-mini_defconfig
@@ -891,3 +891,5 @@ CONFIG_XEN_I2C_BACKEND=y
 CONFIG_XEN_WDT=y
 CONFIG_XEN=y
 CONFIG_XFRM_USER=m
+CONFIG_CMDLINE="balena_stage2"
+CONFIG_CMDLINE_EXTEND=y
