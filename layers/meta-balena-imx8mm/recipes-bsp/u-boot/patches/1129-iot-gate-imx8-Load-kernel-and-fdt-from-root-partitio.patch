From bbeec2ed18695e98db373e69406942a7619306b5 Mon Sep 17 00:00:00 2001
From: Kirill Kapranov <kirill.kapranov@compulab.co.il>
Date: Mon, 29 Jun 2026 20:38:02 +0300
Subject: [PATCH 1129/1129] iot-gate-imx8: Load kernel and fdt from root
 partition

Signed-off-by: Kirill Kapranov <kirill.kapranov@compulab.co.il>
---
 include/configs/cpl-imx8m-mini.h | 7 +++----
 1 file changed, 3 insertions(+), 4 deletions(-)

diff --git a/include/configs/cpl-imx8m-mini.h b/include/configs/cpl-imx8m-mini.h
index d8588b425c9..ebf73db7f1e 100644
--- a/include/configs/cpl-imx8m-mini.h
+++ b/include/configs/cpl-imx8m-mini.h
@@ -60,7 +60,7 @@
 	"setenv usbdev ${resin_dev_index};" \
 	"setenv usbbootpart ${resin_boot_part};" \
 	"setenv mmcdev ${resin_dev_index};" \
-	"setenv mmcbootpart ${resin_boot_part};" \
+	"setenv mmcbootpart ${resin_root_part};" \
 	"for src in "__stringify(BOOT_CANDIDATE_LIST)"; do " \
 		"run ${src}; " \
 		"if run ulbootscript; then " \
@@ -124,9 +124,8 @@
 	"usb_ul=usb start; setenv iface usb; setenv dev 0; setenv part 1;" \
 	"setenv bootargs ${bootargs_common} ${resin_kernel_root} ${root_opt} ${os_cmdline};\0" \
 	"ulbootscript=load ${iface} ${dev}:${part} ${loadaddr} ${script};\0" \
-	"ulimage=load ${iface} ${dev}:${part} ${zip_addr} ${image}; unzip ${zip_addr} ${loadaddr}\0" \
-	"ulfdt=if test ${boot_fdt} = yes || test ${boot_fdt} = try; then " \
-		"load ${iface} ${dev}:${part} ${fdt_addr} ${fdt_file}; fi;\0" \
+	"ulimage=load ${iface} ${resin_dev_index}:${resin_root_part} ${zip_addr} boot/${image}; unzip ${zip_addr} ${loadaddr}\0" \
+	"ulfdt=load ${iface} ${resin_dev_index}:${resin_root_part} ${fdt_addr} boot/${fdt_file};\0" \
 	"bootscript=echo Running bootscript from mmc ...; " \
 		"source\0" \
 	"netargs=setenv bootargs console=${console} " \
-- 
2.34.1

