From c8b61cdd4dafd1435f9329e8af474141956c2e3b Mon Sep 17 00:00:00 2001
From: Kirill Kapranov <kirill.kapranov@compulab.co.il>
Date: Mon, 29 Jun 2026 20:44:26 +0300
Subject: [PATCH] u-boot-compulab: Don't run script if booting with Balena 
 u-boot

The upstream Compulab u-boot script checks if the u-boot present in the second
partition matches the one on the boot devices and if not, updates
the latter and reboots the board, causing a bootcount increment. And this causes
issues when booting in a new OS after the hostOS update.

Let's not run this script when booting a BalenaOS
u-boot.

Upstream-status: Inappropriate [configuration]
Signed-off-by: Alexandru Costache <alexandru@balena.io>
Signed-off-by: Kirill Kapranov <kirill.kapranov@compulab.co.il>
---
 include/configs/cpl-imx8m-mini.h | 16 ++++++----------
 1 file changed, 6 insertions(+), 10 deletions(-)

diff --git a/include/configs/cpl-imx8m-mini.h b/include/configs/cpl-imx8m-mini.h
index ebf73db7f1e..88c17cb2602 100644
--- a/include/configs/cpl-imx8m-mini.h
+++ b/include/configs/cpl-imx8m-mini.h
@@ -63,16 +63,12 @@
 	"setenv mmcbootpart ${resin_root_part};" \
 	"for src in "__stringify(BOOT_CANDIDATE_LIST)"; do " \
 		"run ${src}; " \
-		"if run ulbootscript; then " \
-			"run bootscript; " \
-		"else " \
-			"if run ulimage; then " \
-				"if run ulfdt; then " \
-					"booti ${loadaddr} - ${fdt_addr}; " \
-				"else " \
-					"if test ${boot_fdt} != yes; then " \
-						"booti ${loadaddr}; " \
-					"fi; " \
+		"if run ulimage; then " \
+			"if run ulfdt; then " \
+				"booti ${loadaddr} - ${fdt_addr}; " \
+			"else " \
+				"if test ${boot_fdt} != yes; then " \
+					"booti ${loadaddr}; " \
 				"fi; " \
 			"fi; " \
 		"fi; " \
-- 
2.34.1

